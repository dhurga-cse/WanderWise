# WanderWise Environment Configuration Template
# Copy this file to backend/.env and fill in your actual values

# Server Configuration
PORT=5000

# Database Configuration
# For local MongoDB:
MONGO_URI=mongodb://localhost:27017/wanderwise
# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/wanderwise

# JWT Secret (Change this to a random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Unsplash API (for travel destination images)
# Get your key from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Google Places API (for hotel and restaurant recommendations)
# Get your key from: https://console.cloud.google.com/
# Enable "Places API" in your Google Cloud project
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# OpenRouteService API (for route optimization and maps)
# Get your key from: https://openrouteservice.org/
OPENROUTE_API_KEY=your_openroute_api_key_here

# ============================================
# INSTRUCTIONS TO GET API KEYS (All Free!)
# ============================================

# 1. UNSPLASH API:
#    - Go to https://unsplash.com/developers
#    - Click "Register as a developer"
#    - Create a new application
#    - Copy the "Access Key"
#    - Paste it above

# 2. GOOGLE PLACES API:
#    - Go to https://console.cloud.google.com/
#    - Create a new project (or select existing)
#    - Go to "APIs & Services" > "Library"
#    - Search for "Places API" and enable it
#    - Go to "Credentials" > "Create Credentials" > "API Key"
#    - Copy the API Key
#    - Paste it above

# 3. OPENROUTE SERVICE API:
#    - Go to https://openrouteservice.org/
#    - Click "Sign Up" (free account)
#    - Go to "Dashboard" after login
#    - Click "Request a Token"
#    - Copy the API Key
#    - Paste it above

# ============================================
# IMPORTANT NOTES
# ============================================

# - Never commit this file to version control
# - Keep your API keys secret
# - Use different keys for development and production
# - Most APIs have free tiers with generous limits
# - Check API documentation for rate limits

# ============================================
# TESTING WITHOUT API KEYS
# ============================================

# The app will work without API keys, but:
# - No destination images (Unsplash)
# - No hotel recommendations (Google Places)
# - No restaurant recommendations (Google Places)
# - No route optimization (OpenRouteService)

# Basic features (auth, trips, expenses) work without APIs!
